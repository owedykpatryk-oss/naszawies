    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.104.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "fabric": "^7.4.0",
    "fast-xml-parser": "^5.7.1",
    "fflate": "^0.8.3",
    "html2pdf.js": "^0.14.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "next": "14.2.28",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.12.2",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "eslint": "^8",
    "eslint-config-next": "^14.2.28",
    "pg": "^8.14.1",
    "postcss": "^8",
    "proj4": "^2.20.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
