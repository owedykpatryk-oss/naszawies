{
  "name": "naszawies",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "sync-landing": "node scripts/build-landing-assets.mjs",
    "generuj:marka": "node scripts/przetworz-logo-marki.mjs",
    "generuj-migracje-schema": "node scripts/generuj-migracje-schema-z-dokumentow.mjs",
    "import-teryt": "node scripts/import-teryt.mjs",
    "import-teryt-powiat": "node scripts/import-teryt-powiat.mjs",
    "r2:buckets": "node scripts/r2-buckets.mjs",
    "r2:s3-ping": "node scripts/r2-s3-ping.mjs",
    "r2:deploy-worker": "cd cloudflare/r2-cdn-worker && npx wrangler deploy",
    "wgraj:szablony-maili": "node scripts/wgraj-szablony-maili-supabase.mjs",
    "wlacz:oauth-supabase": "node scripts/wlacz-oauth-supabase.mjs",
    "env:sync-local": "node scripts/uzupelnij-env-local.mjs",
    "sprawdz:env": "node scripts/sprawdz-env.mjs",
    "env:pull-vercel": "vercel env pull .env.vercel.check --environment=production",
    "env:push-vercel": "node scripts/uzupelnij-env-vercel.mjs",
    "env:push-vercel:dry": "node scripts/uzupelnij-env-vercel.mjs --dry-run",
    "db:apply-sql": "node scripts/zastosuj-migracje-sql.mjs",
    "gml:obwody-spisowe-geojson": "node scripts/gml-obwody-spisowe-to-geojson.mjs",
    "import:simc": "node scripts/import-simc-supabase-cli.mjs",
    "import:simc:resume": "node scripts/import-simc-supabase-cli.mjs --resume",
    "sync:granice": "node --experimental-strip-types --env-file=.env.local scripts/synchronizuj-granice-wsi-cli.mjs",
    "sync:granice:wszystkie": "node --experimental-strip-types --env-file=.env.local scripts/synchronizuj-granice-wsi-cli.mjs --tylko-bez-granicy --limit=500",
    "sync:granice:katalog": "node --experimental-strip-types --env-file=.env.local scripts/synchronizuj-granice-wsi-cli.mjs --tylko-bez-granicy --limit=1000 --delay=200",
    "raport:granice": "node scripts/raport-stan-granic.mjs",
    "uzupelnij:gmina-teryt": "node scripts/uzupelnij-gmina-teryt.mjs",
    "automatyzuj:katalog": "npm run import:simc && npm run uzupelnij:gmina-teryt && npm run sync:granice -- --limit=120 --tylko-bez-granicy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
