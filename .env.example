# =============================================================================
# Kopiuj do .env.local i uzupełnij. Nie commituj plików z prawdziwymi sekretami.
# =============================================================================

# -----------------------------------------------------------------------------
# Next.js — NEXT_PUBLIC_* (klient; tylko klucz anon Supabase)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Kanoniczny URL: OAuth + link w mailu potwierdzającym rejestrację (musi być na liście Redirect URLs w Supabase).
# Na Vercel z własną domeną ustaw produkcyjny adres — inaczej link w mailu może wskazywać zły host. Bez końcowego /
# NEXT_PUBLIC_SITE_URL=https://naszawies.pl

# -----------------------------------------------------------------------------
# Cloudflare R2 — S3 API
# -----------------------------------------------------------------------------
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# Publiczny odczyt obiektów (Custom Domain / Worker). Ścieżka: /{bucket}/{klucz}, np. /avatars/uuid/avatar-123.jpg
# CLOUDFLARE_R2_PUBLIC_BASE_URL=https://twoj-cdn.example.com
# CLOUDFLARE_R2_CUSTOM_DOMAIN=https://twoj-cdn.example.com
# Ta sama wartość co wyżej — wtedy klient wgrywa na R2 zamiast Supabase Storage:
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://twoj-cdn.example.com
# CLOUDFLARE_API_TOKEN=   # Account → R2 Storage → Edit — npm run r2:buckets (R2: avatars, hall-inventory, hall-booking-damage — myślniki, bo _ jest zabronione w R2)
# Diagnostyka S3 bez API tokena: npm run r2:s3-ping

# -----------------------------------------------------------------------------
# Resend — kontakt, waitlist, zgłoszenia DSA
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
# RESEND_ZE_STRONY="naszawies <kontakt@twoja-domena.resend.dev>"
# KONTAKT_EMAIL_DOCELOWY=kontakt@naszawies.pl
# ZGLOSZENIA_NARUSZENIA_EMAIL=moderacja@naszawies.pl
# WAITLIST_POWIADOMIENIA_EMAIL=

# -----------------------------------------------------------------------------
# Supabase — serwer / skrypty (import TERYT, bezpośrednie SQL)
# -----------------------------------------------------------------------------
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[HASLO]@....pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Analityka
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=naszawies.pl

# -----------------------------------------------------------------------------
# CI / narzędzia
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=
