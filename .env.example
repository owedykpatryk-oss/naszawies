# Supabase — Project Settings → API (klucz anon, nigdy service_role w NEXT_PUBLIC_*)
# Przykładowy URL: https://TWOJ_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Tylko serwer / skrypty (import TERYT, joby) — nie w NEXT_PUBLIC_*
# SUPABASE_URL= (opcjonalnie; domyślnie import używa NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY=

# Resend — formularz kontaktowy i opcjonalne powiadomienia waitlist
# RESEND_API_KEY=
# RESEND_ZE_STRONY="naszawies <kontakt@twoja-domena.resend.dev>"
# KONTAKT_EMAIL_DOCELOWY=kontakt@naszawies.pl
# WAITLIST_POWIADOMIENIA_EMAIL= (opcjonalnie — kopia zapisu na listę)

# Analityka (opcjonalnie) — domena jak w Plausible, np. naszawies.pl
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=naszawies.pl

# Opcjonalnie na CI (Vercel dodaje zmienne z panelu — nie trzymaj tu sekretów produkcyjnych):
# VERCEL_TOKEN= tylko lokalnie do `vercel deploy`, nie commituj
