# Supabase — Project Settings → API (klucz anon, nigdy service_role w NEXT_PUBLIC_*)
# Przykładowy URL: https://TWOJ_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Analityka (opcjonalnie) — domena jak w Plausible, np. naszawies.pl
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=naszawies.pl

# Opcjonalnie na CI (Vercel dodaje zmienne z panelu — nie trzymaj tu sekretów produkcyjnych):
# VERCEL_TOKEN= tylko lokalnie do `vercel deploy`, nie commituj
