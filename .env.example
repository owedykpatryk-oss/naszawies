# =============================================================================
# Kopiuj do .env.local i uzupełnij. Nie commituj plików z prawdziwymi sekretami.
# =============================================================================

# -----------------------------------------------------------------------------
# Next.js — NEXT_PUBLIC_* (klient; tylko klucz anon Supabase)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Kanoniczny URL: OAuth + link w mailu (Redirect URLs w Supabase). Bez końcowego /
# NEXT_PUBLIC_SITE_URL=https://naszawies.pl

# Wersja pokazywana w /api/health (opcjonalnie)
# NEXT_PUBLIC_APP_VERSION=0.1.0
# NEXT_PUBLIC_WERSJA_APLIKACJI=0.1.0

# -----------------------------------------------------------------------------
# Supabase — serwer (RLS omija service role — tylko route handlers / Server Actions)
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
# Używane m.in. do: powiadomienia dla obserwujących wieś (post), nowe zgłoszenia i zmiana statusu zgłoszenia → obserwatorzy,
# powiadomienia do sołtysów po nowym wniosku o rolę (mieszkaniec / OSP / KGW / rada),
# Web Push do innych użytkowników po ręcznym sync RSS, RSS/cron globalny.
# Bez tej zmiennej: ręczny „Synchronizuj RSS” nadal importuje wpisy (sesja sołtysa), ale push do współadminów może nie dojść;
# sołtysi nie dostaną automatycznego alertu o nowym wniosku o rolę.
# SUPABASE_URL=   # zwykle to samo co NEXT_PUBLIC_SUPABASE_URL
# DATABASE_URL=postgresql://postgres.[REF]:[HASLO]@...pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Vercel Cron — Authorization: Bearer <CRON_SECRET> (vercel.json → /api/.../run, sync)
# -----------------------------------------------------------------------------
CRON_SECRET=
# Automatyczny import POI z OpenStreetMap uruchamiany w /api/automatyzacje/run
# (ostrożnie: publiczny Overpass ma limity; domyślki są bezpieczne)
POI_AUTO_SYNC_VILLAGES_PER_RUN=3
POI_AUTO_SYNC_VILLAGES_SCANNED=30
POI_AUTO_SYNC_MIN_DAYS=7
# Automatyczny import granic wsi z Geoportalu/PRG WFS (bezpieczny tryb, małe limity)
GEOPORTAL_BOUNDARY_SYNC_VILLAGES_PER_RUN=2
GEOPORTAL_BOUNDARY_SYNC_VILLAGES_SCANNED=20
GEOPORTAL_BOUNDARY_SYNC_MIN_DAYS=30
# GEOPORTAL_BOUNDARY_FORCE_REFRESH=0
# WFS PRG: trzeba ustawić poprawny TYPENAME i nazwę pola TERYT dla wybranej warstwy.
GEOPORTAL_PRG_WFS_URL=https://mapy.geoportal.gov.pl/wss/service/PZGIK/PRG/WFS/AdministrativeBoundaries
# GEOPORTAL_PRG_WFS_VERSION=1.1.0
# Przykład dla granic miast z AdministrativeBoundaries:
GEOPORTAL_PRG_WFS_TYPENAME=ms:A06_Granice_obrebow_ewidencyjnych
GEOPORTAL_PRG_WFS_TERYT_FIELD=JPT_KOD_JE
# Automatyczny import adresów i ulic z KIN/PRG WFS
GEOPORTAL_ADDRESS_SYNC_VILLAGES_PER_RUN=1
GEOPORTAL_ADDRESS_SYNC_VILLAGES_SCANNED=10
GEOPORTAL_ADDRESS_SYNC_MIN_DAYS=30
GEOPORTAL_PRG_ADDRESS_WFS_URL=https://mapy.geoportal.gov.pl/wss/ext/KrajowaIntegracjaNumeracjiAdresowej
# GEOPORTAL_PRG_ADDRESS_WFS_VERSION=1.1.0
GEOPORTAL_PRG_ADDRESS_WFS_TYPENAME=ms:prg-adresy
# Opcjonalnie: filtrowanie po SIMC w CQL (jeśli warstwa udostępnia takie pole)
GEOPORTAL_PRG_ADDRESS_SIMC_FIELD=simc
# Kontekst mapy: PRNG + warstwy instytucjonalne PRG
GEOPORTAL_CONTEXT_SYNC_VILLAGES_PER_RUN=1
GEOPORTAL_CONTEXT_SYNC_VILLAGES_SCANNED=8
GEOPORTAL_CONTEXT_SYNC_MIN_DAYS=21
GEOPORTAL_PRNG_WFS_URL=https://mapy.geoportal.gov.pl/wss/service/PZGIK/PRNG/WFS/GeographicalNames
# GEOPORTAL_PRNG_WFS_VERSION=1.1.0
GEOPORTAL_PRNG_WFS_TYPENAME=ms:O1_UrzedoweNazwyObiektowFizjograficznych
GEOPORTAL_PRNG_NAME_FIELD=NAZWAGLOWNA
GEOPORTAL_PRNG_CATEGORY_FIELD=KATEGORIAOBIEKTU
GEOPORTAL_PRG_INSTITUTIONAL_WFS_URL=https://mapy.geoportal.gov.pl/wss/service/PZGIK/PRG/WFS/AdministrativeBoundaries
# GEOPORTAL_PRG_INSTITUTIONAL_WFS_VERSION=1.1.0
# Przykładowe warstwy: PSP (K06,K07), Policja (K02,K09), OC (K11)
GEOPORTAL_PRG_INSTITUTIONAL_TYPENAMES=ms:K06_Komenda_wojewodzka_strazy_pozarnej,ms:K07_Komenda_powiatowa_strazy_pozarnej,ms:K02_Komenda_powiatowa_policji,ms:K09_Placowka_strazy_granicznej
# Opcjonalny podkład referencyjny WMS z Geoportalu (widok mapy publicznej)
# NEXT_PUBLIC_GEOPORTAL_WMS_URL=https://mapy.geoportal.gov.pl/wss/service/PZGIK/ORTO/WMS/StandardResolution
# NEXT_PUBLIC_GEOPORTAL_WMS_LAYERS=Raster

# -----------------------------------------------------------------------------
# Upstash Redis — rate limiting publicznych API
# https://console.upstash.com/
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Cloudflare Turnstile — formularze + walidacja API
# https://dash.cloudflare.com/ → Turnstile
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Sentry — @sentry/nextjs (withSentryConfig tylko gdy SENTRY_DSN)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Cloudflare R2 — S3 API
# -----------------------------------------------------------------------------
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_PUBLIC_BASE_URL=
# CLOUDFLARE_R2_CUSTOM_DOMAIN=
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=
# CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Resend — kontakt, waitlist, zgłoszenia DSA
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
# RESEND_ZE_STRONY="naszawies <kontakt@twoja-domena.resend.dev>"
# KONTAKT_EMAIL_DOCELOWY=kontakt@naszawies.pl
# ZGLOSZENIA_NARUSZENIA_EMAIL=moderacja@naszawies.pl
# WAITLIST_POWIADOMIENIA_EMAIL=

# -----------------------------------------------------------------------------
# Supabase — skrypty (szablony maili Auth, migracje)
# -----------------------------------------------------------------------------
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# -----------------------------------------------------------------------------
# Web Push (VAPID) — para kluczy identyfikuje Twój serwer wobec usługi Push przeglądarki (Chrome/Safari itd.).
# To NIE jest hasło użytkownika — trzymaj VAPID_PRIVATE_KEY tylko po stronie serwera (nigdy w repozytorium).
# Wygeneruj: npx web-push generate-vapid-keys — wklej publiczny do NEXT_PUBLIC_* i prywatny do VAPID_PRIVATE_KEY.
# Na Vercel ustaw te same zmienne w Settings → Environment Variables (Production + Preview).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:twoj-adres@domena.pl

# -----------------------------------------------------------------------------
# Analityka
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=naszawies.pl

# -----------------------------------------------------------------------------
# CI / narzędzia
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=

# -----------------------------------------------------------------------------
# Transport kolejowy (PKP PLK OpenData API) — rozkład i odjazdy stacji
# -----------------------------------------------------------------------------
# PKP_PLK_API_KEY=
# PKP_PLK_API_BASE_URL=https://pdp-api.plk-sa.pl
TRANSPORT_SYNC_ENABLED=1
TRANSPORT_REALTIME_CRON_MINUTES=3
TRANSPORT_PLANNED_SYNC_HOURS=24
TRANSPORT_ALERT_DELAY_MIN=15
# Kontrola jakości danych mapowych (alerty braków po sync)
GEO_QUALITY_CHECK_VILLAGES=150
