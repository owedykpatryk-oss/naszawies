# =============================================================================
# Kopiuj do .env.local i uzupełnij. Nie commituj plików z prawdziwymi sekretami.
#
# Szybki audyt:  npm run sprawdz:env
# Pull z Vercel: npm run env:pull-vercel && npm run sprawdz:env -- --vercel .env.vercel.check
# =============================================================================

# -----------------------------------------------------------------------------
# Wymagane na Vercel Production (minimum działającej aplikacji)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SITE_URL=https://naszawies.pl
# SUPABASE_SERVICE_ROLE_KEY=          ← brak = brak push/cron powiadomień, RSS sync
# CRON_SECRET=
#
# Zalecane na Vercel:
# UPSTASH_REDIS_REST_URL=   ← baza Redis (…-eu1-xxxxx.upstash.io), NIE Upstash Search (…-search.upstash.io)
# UPSTASH_REDIS_REST_TOKEN=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY= + TURNSTILE_SECRET_KEY=
# RESEND_API_KEY= + RESEND_ZE_STRONY=
# TRANSPORT_SYNC_ENABLED=1 + PKP_PLK_API_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY= + VAPID_PRIVATE_KEY= + VAPID_SUBJECT=mailto:…
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Strava API v3 — import aktywności fitness (OAuth)
# https://developers.strava.com/docs/authentication/
# W panelu Strava → My API Application: Authorization Callback Domain = domena produkcyjna
# Redirect URI musi być dokładnie: {NEXT_PUBLIC_SITE_URL}/api/strava/callback
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_OAUTH_STATE_SECRET=   # opcjonalnie — podpis parametru state (domyślnie STRAVA_CLIENT_SECRET)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Next.js — NEXT_PUBLIC_* (klient; tylko klucz anon Supabase)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Kanoniczny URL: OAuth + link w mailu (Redirect URLs w Supabase). Bez końcowego /
# NEXT_PUBLIC_SITE_URL=https://naszawies.pl

# Google OAuth (Supabase Auth → Providers). Redirect URI w Google Cloud:
#   https://<ref-projektu>.supabase.co/auth/v1/callback
# Po uzupełnieniu: npm run wlacz:oauth-supabase
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# Wersja pokazywana w /api/health (opcjonalnie)
# NEXT_PUBLIC_APP_VERSION=0.1.0
# NEXT_PUBLIC_WERSJA_APLIKACJI=0.1.0

# -----------------------------------------------------------------------------
# Supabase — serwer (RLS omija service role — tylko route handlers / Server Actions)
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
# Używane m.in. do: powiadomienia dla obserwujących wieś (post), nowe zgłoszenia i zmiana statusu zgłoszenia → obserwatorzy,
# powiadomienia do sołtysów po nowym wniosku o rolę (mieszkaniec / OSP / KGW / rada),
# Web Push do innych użytkowników po ręcznym sync RSS, RSS/cron globalny.
# Bez tej zmiennej: ręczny „Synchronizuj RSS” nadal importuje wpisy (sesja sołtysa), ale push do współadminów może nie dojść;
# sołtysi nie dostaną automatycznego alertu o nowym wniosku o rolę.
# SUPABASE_URL=   # zwykle to samo co NEXT_PUBLIC_SUPABASE_URL
#
# Połączenie Postgres (migracje lokalne, skrypty SQL, pg_dump):
# Panel Supabase → Project Settings → Database → Connection string (pooler, port 6543)
# DATABASE_URL=postgresql://postgres.[REF]:[HASLO]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Vercel Cron — Authorization: Bearer <CRON_SECRET> (vercel.json → /api/.../run, sync)
# -----------------------------------------------------------------------------
CRON_SECRET=
# GUS BDL API — opcjonalny klucz z https://api.stat.gov.pl/Home/BdlApi (wyższe limity)
# Bez klucza działa tryb anonimowy (wolniej, limity 5 req/s).
GUS_BDL_CLIENT_ID=
# Opcjonalny "tryb miękki" dla /api/kanaly-rss/sync:
# - true/1/on  -> gdy brakuje klucza admin, endpoint zwraca 200 z { ok: true, skipped: true }
# - false/0/off -> gdy brakuje klucza admin, endpoint zwraca 500
# Domyślnie: true poza production, false w production.
# RSS_SYNC_SOFT_SKIP_MISSING_ADMIN=true
# Automatyczny import POI z OpenStreetMap uruchamiany w /api/automatyzacje/run
# (ostrożnie: publiczny Overpass ma limity; domyślki są bezpieczne)
POI_AUTO_SYNC_VILLAGES_PER_RUN=8
POI_AUTO_SYNC_VILLAGES_SCANNED=50
POI_AUTO_SYNC_MIN_DAYS=3

# Ceny paliw — synchronizacja z BenzynaMAPA w /api/automatyzacje/run (domyślnie włączone)
# FUEL_PRICES_SYNC_ENABLED=0
# Automatyczny import granic wsi z Geoportalu/PRG WFS (bezpieczny tryb, małe limity).
# Kolejka (RPC villages_kolejka_sync_granic_prg): najpierw wsi z soltys_user_id lub aktywnymi rolami w user_village_roles,
# potem pozostałe bez boundary_geojson — granica PRG trafia tam, gdzie są ludzie w serwisie.
GEOPORTAL_BOUNDARY_SYNC_VILLAGES_PER_RUN=8
GEOPORTAL_BOUNDARY_SYNC_VILLAGES_SCANNED=60
GEOPORTAL_BOUNDARY_SYNC_MIN_DAYS=14
# Osobny cron /api/mapa/sync-granice + sync z mapy (server action):
GEOPORTAL_BOUNDARY_SYNC_MAPA_PER_RUN=20
GEOPORTAL_BOUNDARY_SYNC_MAPA_SCANNED=150
GEOPORTAL_BOUNDARY_SYNC_MAPA_MIN_DAYS=3
# GEOPORTAL_BOUNDARY_FORCE_REFRESH=0
# WFS PRG: trzeba ustawić poprawny TYPENAME i nazwę pola TERYT dla wybranej warstwy.
GEOPORTAL_PRG_WFS_URL=https://mapy.geoportal.gov.pl/wss/service/PZGIK/PRG/WFS/AdministrativeBoundaries
# Geoportal PRG AdministrativeBoundaries działa stabilnie na WFS 1.1.0
GEOPORTAL_PRG_WFS_VERSION=1.1.0
# Uwaga: w tej usłudze nie ma osobnej warstwy sołectw; najbliższa urzędowa geometria to jednostka ewidencyjna (A05) lub obręb (A06).
# Bez env klient próbuje A05 → A06 z formatem GML2. Możesz też ustawić listę warstw:
# GEOPORTAL_PRG_WFS_LAYERS=A05_Granice_jednostek_ewidencyjnych,A06_Granice_obrebow_ewidencyjnych
# GEOPORTAL_PRG_WFS_TYPENAME=A05_Granice_jednostek_ewidencyjnych
GEOPORTAL_PRG_WFS_TERYT_FIELD=JPT_KOD_JE
# Warstwy granic — klient próbuje A05, potem A06 (zamiast pojedynczego TYPENAME):
GEOPORTAL_PRG_WFS_LAYERS=A05_Granice_jednostek_ewidencyjnych,A06_Granice_obrebow_ewidencyjnych
# GEOPORTAL_PRG_WFS_TYPENAME=A05_Granice_jednostek_ewidencyjnych
# Automatyczny import adresów i ulic z KIN/PRG WFS
GEOPORTAL_ADDRESS_SYNC_VILLAGES_PER_RUN=3
GEOPORTAL_ADDRESS_SYNC_VILLAGES_SCANNED=20
GEOPORTAL_ADDRESS_SYNC_MIN_DAYS=30
GEOPORTAL_PRG_ADDRESS_WFS_URL=https://mapy.geoportal.gov.pl/wss/ext/KrajowaIntegracjaNumeracjiAdresowej
# GEOPORTAL_PRG_ADDRESS_WFS_VERSION=1.1.0
GEOPORTAL_PRG_ADDRESS_WFS_TYPENAME=ms:prg-adresy
# Opcjonalnie: filtrowanie po SIMC w CQL (jeśli warstwa udostępnia takie pole)
GEOPORTAL_PRG_ADDRESS_SIMC_FIELD=simc
# Kontekst mapy: PRNG + warstwy instytucjonalne PRG
GEOPORTAL_CONTEXT_SYNC_VILLAGES_PER_RUN=1
GEOPORTAL_CONTEXT_SYNC_VILLAGES_SCANNED=8
GEOPORTAL_CONTEXT_SYNC_MIN_DAYS=21
GEOPORTAL_PRNG_WFS_URL=https://mapy.geoportal.gov.pl/wss/service/PZGIK/PRNG/WFS/GeographicalNames
# GEOPORTAL_PRNG_WFS_VERSION=1.1.0
# Bez prefiksu ms: — Geoportal zwraca GML2 (nie JSON); klient obsługuje oba formaty
GEOPORTAL_PRNG_WFS_TYPENAMES=O1_UrzedoweNazwyObiektowFizjograficznych,O2_ZestandaryzowaneNazwyObiektowFizjograficznych,O3_PozostaleNazwyObiektowFizjograficznych
# GEOPORTAL_PRNG_WFS_TYPENAME=O1_UrzedoweNazwyObiektowFizjograficznych
GEOPORTAL_PRNG_NAME_FIELD=NAZWAGLOWNA
GEOPORTAL_PRNG_CATEGORY_FIELD=KATEGORIAOBIEKTU
GEOPORTAL_PRG_INSTITUTIONAL_WFS_URL=https://mapy.geoportal.gov.pl/wss/service/PZGIK/PRG/WFS/AdministrativeBoundaries
# GEOPORTAL_PRG_INSTITUTIONAL_WFS_VERSION=1.1.0
# Przykładowe warstwy: PSP (K06,K07), Policja (K02,K09), OC (K11)
# OSP (K07), policja, nadleśnictwo, urząd skarbowy, ZWiK — granice komórek organizacyjnych
GEOPORTAL_PRG_INSTITUTIONAL_TYPENAMES=K07_Komenda_powiatowa_strazy_pozarnej,K11_Ochotnicza_straz_pozarna,K02_Komenda_powiatowa_policji,K04_Komenda_rejonowa_policji,K05_Komisariat_policji,U06_Nadlesnictwo,U07_Regionalna_dyrekcja_lasow_panstwowych,U02_Urzad_skarbowy,U09_Regionalny_zarzad_gospodarki_wodnej_PGWWP,S03_Sad_rejonowy,Z02_Szkola_podstawowa,Z03_Przedszkole
# Opcjonalny podkład referencyjny WMS z Geoportalu (widok mapy publicznej)
NEXT_PUBLIC_GEOPORTAL_WMS_URL=https://mapy.geoportal.gov.pl/wss/service/PZGIK/ORTO/WMS/StandardResolution
NEXT_PUBLIC_GEOPORTAL_WMS_LAYERS=Raster

# Granice katastralne EGiB (obręby + działki) — włączone na mapie i przy ogłoszeniach z działką
NEXT_PUBLIC_GEOPORTAL_EGIB_WMS_URL=https://integracja.gugik.gov.pl/cgi-bin/KrajowaIntegracjaEwidencjiGruntow
NEXT_PUBLIC_GEOPORTAL_EGIB_WMS_LAYERS=obreby,dzialki
# POI na mapie z warstw PRG/PRNG (geo_context_features → pois, source=geoportal)
GEOPORTAL_POI_SYNC_ENABLED=1
GEOPORTAL_POI_SYNC_VILLAGES_PER_RUN=4

# -----------------------------------------------------------------------------
# Upstash Redis — rate limiting publicznych API
# https://console.upstash.com/
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Cloudflare Turnstile — formularze + walidacja API
# https://dash.cloudflare.com/ → Turnstile
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Sentry — @sentry/nextjs (withSentryConfig tylko gdy SENTRY_DSN)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Cloudflare R2 — S3 API + publiczny CDN
# Pełna instrukcja: docs/CLOUDFLARE.md
# -----------------------------------------------------------------------------
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# Publiczny CDN (Worker naszawies-r2-cdn → custom domain, np. cdn.naszawies.pl):
# CLOUDFLARE_R2_PUBLIC_BASE_URL=https://cdn.naszawies.pl
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://cdn.naszawies.pl
# Włącza upload na R2 zamiast Supabase Storage gdy ustawione ↑
# Miniaturki przez Cloudflare Image Resizing (wymaga funkcji na strefie):
# NEXT_PUBLIC_R2_CDN_IMAGES=1
# Token do npm run r2:buckets i r2:deploy-worker (Account → R2 Storage → Edit):
# CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Resend — kontakt, waitlist, zgłoszenia DSA
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
# RESEND_ZE_STRONY="naszawies <kontakt@twoja-domena.resend.dev>"
# KONTAKT_EMAIL_DOCELOWY=kontakt@naszawies.pl
# ZGLOSZENIA_NARUSZENIA_EMAIL=moderacja@naszawies.pl
# WAITLIST_POWIADOMIENIA_EMAIL=

# -----------------------------------------------------------------------------
# Supabase — skrypty (szablony maili Auth, migracje)
# -----------------------------------------------------------------------------
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# -----------------------------------------------------------------------------
# Web Push (VAPID) — para kluczy identyfikuje Twój serwer wobec usługi Push przeglądarki (Chrome/Safari itd.).
# To NIE jest hasło użytkownika — trzymaj VAPID_PRIVATE_KEY tylko po stronie serwera (nigdy w repozytorium).
# Wygeneruj: npx web-push generate-vapid-keys — wklej publiczny do NEXT_PUBLIC_* i prywatny do VAPID_PRIVATE_KEY.
# Na Vercel ustaw te same zmienne w Settings → Environment Variables (Production + Preview).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:twoj-adres@domena.pl

# -----------------------------------------------------------------------------
# Analityka
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=naszawies.pl

# RODO — dane administratora na stronie polityki prywatności (opcjonalnie)
# NEXT_PUBLIC_LEGAL_ADMIN_NAME=Jan Kowalski / Nazwa spółki
# NEXT_PUBLIC_LEGAL_ADMIN_ADDRESS=ul. …, 00-000 Miasto

# Opinie użytkowników (powiadomienie e-mail po nowej sugestii; domyślnie jak kontakt)
# FEEDBACK_EMAIL_DOCELOWY=rodo@naszawies.pl

# -----------------------------------------------------------------------------
# CI / narzędzia
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=

# -----------------------------------------------------------------------------
# Transport kolejowy (PKP PLK OpenData API) — rozkład i odjazdy stacji
# -----------------------------------------------------------------------------
# PKP_PLK_API_KEY=
# PKP_PLK_API_BASE_URL=https://pdp-api.plk-sa.pl
TRANSPORT_SYNC_ENABLED=1
TRANSPORT_REALTIME_CRON_MINUTES=3
TRANSPORT_PLANNED_SYNC_HOURS=24
TRANSPORT_ALERT_DELAY_MIN=15
# Autobusy — cache w bus_departures_cache (cron /api/automatyzacje/run)
TRANSPORT_BUS_SYNC_ENABLED=1
# Przy sync GTFS: automatycznie dopisz POI „przystanek” z stops.txt (0 = wyłącz)
TRANSPORT_AUTO_CREATE_STOP_POI=1
# GTFS: ZIP (zalecane, np. https://mkuran.pl/gtfs/lublin.zip) lub osobne CSV
# TRANSPORT_GTFS_ZIP_URL=https://mkuran.pl/gtfs/lublin.zip
# TRANSPORT_GTFS_STOPS_URL=
# TRANSPORT_GTFS_STOP_TIMES_URL=
# e-podróżnik (umowa API — endpoint może wymagać dopasowania w epodroznik-api.ts)
# TRANSPORT_EPODROZNIK_ENABLED=1
# EPODROZNIK_API_KEY=
# EPODROZNIK_API_BASE_URL=https://api.e-podroznik.pl
# EPODROZNIK_DEPARTURES_PATH=/v1/departures/nearby
# Kontrola jakości danych mapowych (alerty braków po sync)
GEO_QUALITY_CHECK_VILLAGES=150
